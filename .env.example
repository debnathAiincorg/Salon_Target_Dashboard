# Azure AD Application (client credentials) configuration
# Required for fetching Daily_Invoice.xlsx from SharePoint via Microsoft Graph API
# See README for setup instructions

# Azure AD tenant ID (UUID)
AZURE_TENANT_ID=<your-tenant-id-uuid>

# Azure AD app client ID (UUID)
AZURE_CLIENT_ID=<your-client-id-uuid>

# Azure AD app client secret (generated in Azure portal)
AZURE_CLIENT_SECRET=<your-client-secret>

# SharePoint share link
# URL to the Daily_Invoice.xlsx file in SharePoint
# Example: https://cloudaiorg.sharepoint.com/:x:/r/sites/Accounts2/...
SHAREPOINT_SHARE_LINK=<your-sharepoint-share-link>